# AutoSprite REST API key for tools/gen_assets.mjs
# Create one at https://www.autosprite.io/apikey (works for REST + MCP).
# Sent as the `x-api-key` header. Never commit your real key.
AUTO_SPRITE_AUTH=vspk_xxxxxxxxxx_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the API base (defaults to https://www.autosprite.io/api/v1)
# AUTO_SPRITE_BASE=https://www.autosprite.io/api/v1
